{
  "name": "smart-stadium-nexus",
  "version": "1.0.0",
  "description": "AI-powered smart stadium crowd management system using Google Cloud, Firebase Realtime Database, Vertex AI, and Gemini for real-time fan routing, crowd prediction, and exit wave management at large-scale sporting venues.",
  "keywords": [
    "stadium",
    "crowd-management",
    "firebase",
    "gemini-ai",
    "vertex-ai",
    "google-cloud",
    "react",
    "real-time",
    "iot",
    "smart-venue"
  ],
  "private": true,
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run --reporter=verbose",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "coverage": "vitest run --coverage",
    "lint": "eslint src --ext .js,.jsx --report-unused-disable-directives --max-warnings 0",
    "deploy": "npm run build && firebase deploy"
  },
  "dependencies": {
    "@googlemaps/js-api-loader": "^1.16.6",
    "clsx": "^2.1.0",
    "firebase": "^10.7.0",
    "lucide-react": "^0.363.0",
    "prop-types": "^15.8.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "recharts": "^2.12.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.4.2",
    "@testing-library/react": "^14.2.1",
    "@vitest/coverage-v8": "^1.3.1",
    "@types/react": "^18.2.56",
    "@types/react-dom": "^18.2.19",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.18",
    "eslint": "^8.56.0",
    "eslint-plugin-react": "^7.33.2",
    "eslint-plugin-react-hooks": "^4.6.0",
    "jsdom": "^29.0.2",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.1",
    "vite": "^5.1.4",
    "vitest": "^1.3.1"
  },
  "vitest": {
    "environment": "jsdom",
    "globals": true,
    "setupFiles": [
      "./src/tests/setup.js"
    ],
    "include": [
      "src/tests/**/*.test.{js,jsx}",
      "tests/**/*.test.{js,jsx}"
    ],
    "coverage": {
      "provider": "v8",
      "reporter": [
        "text",
        "html"
      ],
      "include": [
        "src/**/*.{js,jsx}"
      ],
      "exclude": [
        "src/tests/**",
        "src/main.jsx"
      ]
    }
  }
}